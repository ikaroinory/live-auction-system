generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum ProductAuctionStatus {
  NOT_STARTED
  IN_PROGRESS
  ENDED
}

enum ProductStatus {
  PENDING
  PUBLISHED
}

enum ProductTag {
  LATE_COMPENSATION
  FREE_SHIPPING
  SHIPPING_INSURANCE
  AUCTION
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  nickname  String?
  avatar    String?  @db.LongText
  bio       String?  @db.Text
  gender    Gender   @default(UNKNOWN)
  birthday  DateTime?
  location  String   @default("未知")
  douyinId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  liveRooms     LiveRoom[]       @relation("UserToLiveRoom")
  followedRooms LiveRoomFollow[] @relation("UserToLiveRoomFollow")
  products      Product[]        @relation("UserToProduct")
}

model LiveRoom {
  id          String    @id @default(uuid())
  roomNumber  Int       @unique @default(autoincrement())
  streamerId  String
  title       String
  description String?   @db.Text
  coverImage  String?   @db.LongText
  status      Int       @default(0) // 0:未开始 1:直播中 2:已结束
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联关系
  streamer  User           @relation("UserToLiveRoom", fields: [streamerId], references: [id])
  followers LiveRoomFollow[] @relation("LiveRoomToLiveRoomFollow")

  @@index([status])
  @@index([streamerId])
}

model LiveRoomFollow {
  id         String   @id @default(uuid())
  userId     String
  liveRoomId String
  createdAt  DateTime @default(now())

  // 关联关系
  user      User     @relation("UserToLiveRoomFollow", fields: [userId], references: [id], onDelete: Cascade)
  liveRoom  LiveRoom @relation("LiveRoomToLiveRoomFollow", fields: [liveRoomId], references: [id], onDelete: Cascade)

  @@unique([userId, liveRoomId])
  @@index([userId])
  @@index([liveRoomId])
}

model Product {
  id               String               @id @default(uuid())
  creatorId        String
  name             String
  image            String               @db.LongText
  startingPrice    Decimal              @db.Decimal(10, 2)
  fixedIncrement   Decimal              @db.Decimal(10, 2)
  maxPrice         Decimal?             @db.Decimal(10, 2)
  tags             Json                 @default("[]")
  // 竞拍相关字段
  durationMinutes  Int                  @default(60) // 默认竞拍时长：60分钟（1小时）
  extendSeconds    Int                  @default(15)  // 出价延时：默认15秒
  auctionStatus    ProductAuctionStatus @default(NOT_STARTED)
  auctionStartTime DateTime?
  auctionEndTime   DateTime?
  currentBidPrice  Decimal?             @db.Decimal(10, 2)
  bidCount         Int                  @default(0)
  status           ProductStatus        @default(PENDING) // PENDING: 待上架 PUBLISHED: 已上架
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  // 关联关系
  creator  User     @relation("UserToProduct", fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([createdAt])
  @@index([status])
}

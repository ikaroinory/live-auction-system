generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum ProductAuctionStatus {
  NOT_STARTED
  IN_PROGRESS
  ENDED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  nickname  String?
  avatar    String?  @db.LongText
  bio       String?  @db.Text
  gender    Gender   @default(UNKNOWN)
  birthday  DateTime?
  location  String   @default("未知")
  douyinId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联关系
  auctions      Auction[]        @relation("sellerAuctions")
  bids          Bid[]
  orders        Order[]          @relation("userOrders")
  soldOrders    Order[]          @relation("sellerOrders")
  wonAuctions   Auction[]        @relation("winnerAuctions")
  liveRooms     LiveRoom[]       @relation("UserToLiveRoom")
  followedRooms LiveRoomFollow[] @relation("UserToLiveRoomFollow")
  products      Product[]        @relation("UserToProduct")
}

model Auction {
  id                String    @id @default(uuid())
  sellerId          String
  liveRoomId        String?
  productId         String?
  title             String
  description       String?
  images            Json?
  startPrice        Decimal   @db.Decimal(10, 2)
  minIncrement      Decimal   @db.Decimal(10, 2)
  maxPrice          Decimal?  @db.Decimal(10, 2)
  durationSeconds   Int
  autoExtendSeconds Int       @default(15)
  status            Int       @default(0) // 0:未开始 1:进行中 2:已结束 3:已取消
  startTime         DateTime?
  endTime           DateTime?
  finalPrice        Decimal?  @db.Decimal(10, 2)
  winnerId          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // 关联关系
  seller   User      @relation("sellerAuctions", fields: [sellerId], references: [id])
  winner   User?     @relation("winnerAuctions", fields: [winnerId], references: [id])
  liveRoom LiveRoom? @relation(fields: [liveRoomId], references: [id])
  product  Product?  @relation("ProductToAuction", fields: [productId], references: [id])
  bids     Bid[]
  order    Order?

  @@index([status])
  @@index([startTime])
  @@index([liveRoomId])
  @@index([productId])
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  userId    String
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @db.DateTime(3)

  // 关联关系
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([auctionId, userId, price])
  @@index([auctionId, createdAt])
}

model Order {
  id         String    @id @default(uuid())
  auctionId  String    @unique
  userId     String
  sellerId   String
  finalPrice Decimal   @db.Decimal(10, 2)
  status     Int       @default(0) // 0:待支付 1:已支付 2:已取消
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 关联关系
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation("userOrders", fields: [userId], references: [id])
  seller  User    @relation("sellerOrders", fields: [sellerId], references: [id])
}

model LiveRoom {
  id          String    @id @default(uuid())
  roomNumber  Int       @unique @default(autoincrement())
  streamerId  String
  title       String
  description String?   @db.Text
  coverImage  String?   @db.LongText
  status      Int       @default(0) // 0:未开始 1:直播中 2:已结束
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联关系
  streamer  User           @relation("UserToLiveRoom", fields: [streamerId], references: [id])
  followers LiveRoomFollow[] @relation("LiveRoomToLiveRoomFollow")
  auctions  Auction[]

  @@index([status])
  @@index([streamerId])
}

model LiveRoomFollow {
  id         String   @id @default(uuid())
  userId     String
  liveRoomId String
  createdAt  DateTime @default(now())

  // 关联关系
  user      User     @relation("UserToLiveRoomFollow", fields: [userId], references: [id], onDelete: Cascade)
  liveRoom  LiveRoom @relation("LiveRoomToLiveRoomFollow", fields: [liveRoomId], references: [id], onDelete: Cascade)

  @@unique([userId, liveRoomId])
  @@index([userId])
  @@index([liveRoomId])
}

model Product {
  id               String               @id @default(uuid())
  creatorId        String
  name             String
  image            String               @db.LongText
  startingPrice    Decimal              @db.Decimal(10, 2)
  fixedIncrement   Decimal              @db.Decimal(10, 2)
  maxPrice         Decimal?             @db.Decimal(10, 2)
  lateCompensation Boolean              @default(false)
  freeShipping     Boolean              @default(false)
  shippingInsurance Boolean             @default(false)
  auction          Boolean              @default(false)
  isExplaining     Boolean              @default(false)
  // 竞拍相关字段
  durationMinutes  Int                  @default(60) // 默认竞拍时长：60分钟（1小时）
  extendSeconds    Int                  @default(15)  // 出价延时：默认15秒
  auctionStatus    ProductAuctionStatus @default(NOT_STARTED)
  auctionStartTime DateTime?
  auctionEndTime   DateTime?
  currentBidPrice  Decimal?             @db.Decimal(10, 2)
  bidCount         Int                  @default(0)
  status           ProductStatus        @default(DRAFT) // DRAFT: 待上架 PUBLISHED: 已上架
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  // 关联关系
  creator  User     @relation("UserToProduct", fields: [creatorId], references: [id])
  auctions Auction[] @relation("ProductToAuction")

  @@index([creatorId])
  @@index([createdAt])
  @@index([status])
}

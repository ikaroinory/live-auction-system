# 服务器配置
PORT=3001

# 数据库连接
DATABASE_URL="mysql://root:password@localhost:3306/live_auction_db?schema=public"

# JWT 密钥
JWT_SECRET="your-secret-key-change-in-production"

# ==================== Redis 配置 ====================
# Redis服务器地址，支持IP地址或域名
REDIS_HOST="localhost"
# Redis端口号，默认6379
REDIS_PORT=6379
# Redis密码，如果没有设置密码则留空
REDIS_PASSWORD=""
# Redis数据库编号，范围0-15，默认为0
REDIS_DB=0
# Redis连接超时时间（毫秒），建议设置为30000（30秒）
REDIS_TIMEOUT=30000
# Redis连接池最大连接数，根据业务量调整
REDIS_MAX_CONNECTIONS=10
# Redis键前缀，用于区分不同环境或应用的数据
REDIS_KEY_PREFIX="auction:"